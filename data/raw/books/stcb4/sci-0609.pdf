/*# sourceURL=global-styles-inline-css */</style><link rel='stylesheet' id='copyrightclearancecenter-2021-style-css' href='https://www.copyright.com/wp-content/cache/autoptimize/1/css/autoptimize_single_bf0a0213374532a979be17b88907d4e3.css?ver=d054afaf15f95ac77169cdc5965fb663' type='text/css' media='all' /><link rel='stylesheet' id='owl-carousel-core-css' href='https://www.copyright.com/wp-content/themes/copyrightclearancecenter/assets/css/owl.carousel.min.css?ver=2.3.4' type='text/css' media='all' /><link rel='stylesheet' id='copyrightclearancecenter-modal-css' href='https://www.copyright.com/wp-content/cache/autoptimize/1/css/autoptimize_single_a09da131cdf7def6bcb2070ccfeb44fe.css?ver=d054afaf15f95ac77169cdc5965fb663' type='text/css' media='all' /><link rel='stylesheet' id='ringgold-40451-css' href='https://www.copyright.com/wp-content/cache/autoptimize/1/css/autoptimize_single_43d8264410a68f46e8f76b4bb6fef3fb.css?ver=1.0.1' type='text/css' media='all' /> <script defer type="text/javascript" src="https://www.copyright.com/wp-includes/js/jquery/jquery.min.js?ver=3.7.1" id="jquery-core-js"></script> <script defer type="text/javascript" src="https://www.copyright.com/wp-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1" id="jquery-migrate-js"></script> <script defer id="mashsb-js-extra" src="data:text/javascript;base64,"></script> <script defer type="text/javascript" src="https://www.copyright.com/wp-content/plugins/mashsharer/assets/js/mashsb.min.js?ver=4.0.47" id="mashsb-js"></script> <script defer id="mashnet-js-extra" src="data:text/javascript;base64,Ci8qIDwhW0NEQVRBWyAqLwp2YXIgbWFzaG5ldCA9IHsiYm9keSI6IiIsInN1YmplY3QiOiIiLCJwaW50ZXJlc3Rfc2VsZWN0IjoiMCJ9OwovLyMgc291cmNlVVJMPW1hc2huZXQtanMtZXh0cmEKLyogXV0+ICovCg=="></script> <script defer type="text/javascript" src="https://www.copyright.com/wp-content/plugins/mashshare-networks/assets/js/mashnet.min.js?ver=2.4.2" id="mashnet-js"></script> <script defer type="text/javascript" src="https://www.copyright.com/wp-content/cache/autoptimize/1/js/autoptimize_single_1a43a8273123218b068c531cc14d765b.js?ver=2.2.1" id="copyrightclearancecenter-cookie-js"></script> <script defer type="text/javascript" src="https://www.copyright.com/wp-content/themes/copyrightclearancecenter/assets/js/plugins/owl.carousel.min.js?ver=2.3.4" id="owl-carousel-js"></script> <link rel="https://api.w.org/" href="https://www.copyright.com/wp-json/" /><link rel="alternate" title="JSON" type="application/json" href="https://www.copyright.com/wp-json/wp/v2/pages/40451" /><link rel="EditURI" type="application/rsd+xml" title="RSD" href="https://www.copyright.com/xmlrpc.php?rsd" /><link rel='shortlink' href='https://www.copyright.com/?p=40451' />  <script data-cfasync="false" data-pagespeed-no-defer>var dataLayer_content = {"pageTitle":"Persistent Identifiers and Rich Metadata | Ringgold","pagePostType":"page","pagePostType2":"single-page","pagePostDate":"10-Oct-2022","pagePostDateYear":2022,"pagePostDateMonth":10,"pagePostDateDay":10,"pagePostDateDayName":"Monday","pagePostDateHour":20,"pagePostDateMinute":27,"pagePostDateIso":"2022-10-10T20:27:46+00:00","pagePostDateUnix":1665433666,"pagePostTerms":{"internal_tag":["persistent identifiers","PIDs","Publishing","Ringgold","Solution"],"author":["copyright-clearance-center-admin"],"meta":{"mashsb_timestamp":1779953539,"mashsb_twitter_handle":"copyrightclear","alt_hero_placement":0,"show_title_in_hero":0,"show_tint":0,"hide_post_thumbnail":0,"featured_image_position":"right","featured_image_video_id":"","featured_image_video_source":"wistia","featured_image_video":"","hide_header_cta":0,"hide_navigation":0,"hide_breadcrumbs":0,"hide_banner":0,"hide_footer":0,"hide_footer_top":0,"hide_footer_bottom":0,"icon":"icon-ringgold-solutions","solution_type":"services","product_sheet_link":"https:\/\/www.copyright.com\/wp-content\/uploads\/2023\/04\/ringgold-solutions-product-sheet.pdf","product_sheet_link_text":"","product_sheet_graphic":43880,"cta_link":"other","footer_cta_text":"Improve the quality of organization data with the leading organization persistent identifier (PID) solution trusted by 80 publishers, service providers, and funders for 20 years","footer_cta_hide_solution_name":1,"footer_cta_link":"https:\/\/www.copyright.com\/landing\/contact-ringgold\/","footer_cta_link_text":"","footer_cta":"","solutions_modules":"a:7:{i:0;s:12:\"open_content\";i:1;s:11:\"cta_columns\";i:2;s:14:\"by_the_numbers\";i:3;s:12:\"open_content\";i:4;s:17:\"case_study_slider\";i:5;s:15:\"resources_cards\";i:6;s:9:\"link_list\";}","hide_sidebar":1,"sidebar_menu":"","sidebar_items":"","solutions_modules_2_content_blocks_0_custom_content_url":"","solutions_modules_2_content_blocks_1_custom_content_url":"","solutions_modules_2_content_blocks_2_custom_content_url":"","mashsb_shares":0,"mashsb_jsonshares":"{\"total\":0}","hero_secondary_cta_link":"","hero_secondary_cta_link_text":"","hero_secondary_cta_link_target":0,"hero_secondary_cta":"","footer_cta_layout":"2-column","featured_solution_title_override":"","excerpt_font_size":"has-font-size-ccc-h6","solutions_modules_2_title":"Ringgold by the numbers","solutions_modules_2_content":"","solutions_modules_2_cards_0_card":"\r\n      770,000+organization records, each with a unique Ringgold ID, rich hierarchies, and over 30 descriptive metadata elements\r\n","solutions_modules_2_cards_1_card":"\r\n  Used by \r\n  80 leading publishers, service providers, and funders\r\n","solutions_modules_2_cards_2_card":"\r\n      99.9%+of Ringgold ID's have a corresponding ISNI ID\r\n","solutions_modules_2_cards_3_card":"\r\n      32,300 +funder records\r\n","solutions_modules_2_cards_4_card":"\r\n      139,000 +new records added in the past 12 months\r\n","solutions_modules_2_cards_5_card":"\r\n      254,000 +records updated in the last 12 months\r\n","solutions_modules_2_cards":6,"show_content_in_hero":0,"hide_ccc_logo":0,"branding":"","show_product_sheet_in_header":1,"ao_post_optimize":"a:6:{s:16:\"ao_post_optimize\";s:2:\"on\";s:19:\"ao_post_js_optimize\";s:2:\"on\";s:20:\"ao_post_css_optimize\";s:2:\"on\";s:12:\"ao_post_ccss\";s:2:\"on\";s:16:\"ao_post_lazyload\";s:2:\"on\";s:15:\"ao_post_preload\";s:0:\"\";}","footnotes":"","use_compact_header":0,"solution_icon":"","custom_solution_title":"Ringgold","featured_image_left_wide_screen":1,"header_background_color":"has-ringgold-gold-to-white-gold-gradient-background-color","hero_video_button_cta_id":"evi29ngkfe","hero_video_button_cta_link_text":"Play","hero_video_button_cta":"","header_accordion":3,"logo_wall_title":"Trusted by","logo_wall_logos":"a:4:{i:0;s:5:\"54373\";i:1;s:5:\"54372\";i:2;s:5:\"54371\";i:3;s:5:\"54370\";}","logo_wall":"","logo_wall_opacity":70,"footer_cta_before_link_content":"","inline_featured_image":"","cta_link_other_link_text":"Request information","cta_link_other_link":"https:\/\/www.copyright.com\/landing\/contact-ringgold\/","cta_link_other":"","header_accordion_0_title":"Increase interoperability and efficiency with PIDs","header_accordion_0_content":"Connect your systems, streamline publishing workflows, and eliminate data siloes with Ringgold's market-leading persistent identifiers. Ringgold IDs link multiple datasets across systems, eliminating manual processes typically used by data teams when unifying multiple datasets. Ringgold also supports ISNI (an ISO standard – ISO 27729) as a bridge identifier to enable connections of different datasets in support of broader interoperability.","header_accordion_1_title":"Make confident decisions with high-quality data","header_accordion_1_content":"Ringgold's unparalleled data quality helps you fuel confident, data-driven strategic decisions and streamline reporting on research activity, funding, and organization affiliations. CCC has implemented dozens of different data quality metrics, analyzing completeness, consistency, currency, and redundancy, to continually improve the quality of Ringgold data.","header_accordion_2_title":"Save time on manual data cleanup","header_accordion_2_content":"Free your teams from spending time on manual data cleanup with expertly curated, normalized, and enriched organization data delivered by CCC’s data management experts, who have over 200 years’ collective experience.","footer_cta_kicker":"Ringgold","footer_cta_secondary_link":"","footer_cta_secondary_link_text":"","solutions_modules_0_kicker":"","solutions_modules_0_title":"","solutions_modules_0_title_link":"","solutions_modules_0_sections_0_content":"\r\nTrusted data about global organizations engaged in scholarly research\r\nRinggold Organizations provides publishers and service providers trusted, high-quality data to fuel confident, strategic decisions, streamline reporting, and support interoperability with an expertly curated database of global organizations that fund, create, and use scholarly research.\r\nProduct sheet","solutions_modules_0_sections_0_content_width":"seven-eighths","solutions_modules_0_sections_0_desktop_column_width":"desk-one-half","solutions_modules_0_sections_1_content":"\r\n\r\nPersistent identifiers (PIDs) uniquely identify your organization. \u2028Find your organization's Ringgold ID or ISNI ID using our complimentary lookup service, or request a new ID.\r\nGet Your Organization ID","solutions_modules_0_sections_1_content_width":"seven-eighths","solutions_modules_0_sections_1_desktop_column_width":"desk-one-half","solutions_modules_0_sections":2,"solutions_modules_0_vertical_alignment":"are-vertically-aligned-center","solutions_modules_0_background_color":"has-ringgold-white-gold-1-background-color","solutions_modules_0_section_padding":"stage--has-default-padding","solutions_modules_1_title":"Additional Services","solutions_modules_1_title_link":"","solutions_modules_1_max_title_width":"lap-and-up-one-whole","solutions_modules_1_content_blocks_0_custom_content_image":54260,"solutions_modules_1_content_blocks_0_custom_content_title":"Ringgold Audit Service","solutions_modules_1_content_blocks_0_custom_content_title_size":"h4","solutions_modules_1_content_blocks_0_custom_content_content":"Normalize and enrich your data.\r\n\r\nLeverage trusted data experts to help you normalize and enrich your data to create a clean, comprehensive set of global organization data.\r\nProduct sheet","solutions_modules_1_content_blocks_0_custom_content_link":"https:\/\/www.copyright.com\/wp-content\/uploads\/2024\/03\/Ringgold-Audit-Service.pdf","solutions_modules_1_content_blocks_0_custom_content_open_link_in_new_window":1,"solutions_modules_1_content_blocks_0_custom_content":"","solutions_modules_1_content_blocks_0_button_link":"","solutions_modules_1_content_blocks_0_button_link_text":"","solutions_modules_1_content_blocks_0_button_open_link_in_new_window":0,"solutions_modules_1_content_blocks_0_button":"","solutions_modules_1_content_blocks_1_custom_content_image":54261,"solutions_modules_1_content_blocks_1_custom_content_title":"Ringgold Validate Service","solutions_modules_1_content_blocks_1_custom_content_title_size":"h4","solutions_modules_1_content_blocks_1_custom_content_content":"Create new Ringgold IDs on demand.\r\n\r\nEnables Ringgold Organizations users to immediately generate new Ringgold IDs for organizations not currently held in our database.","solutions_modules_1_content_blocks_1_custom_content_link":"","solutions_modules_1_content_blocks_1_custom_content_open_link_in_new_window":0,"solutions_modules_1_content_blocks_1_custom_content":"","solutions_modules_1_content_blocks_1_button_link":"","solutions_modules_1_content_blocks_1_button_link_text":"","solutions_modules_1_content_blocks_1_button_open_link_in_new_window":0,"solutions_modules_1_content_blocks_1_button":"","solutions_modules_1_content_blocks_2_custom_content_image":54262,"solutions_modules_1_content_blocks_2_custom_content_title":"Ringgold Consortium Directory","solutions_modules_1_content_blocks_2_custom_content_title_size":"h4","solutions_modules_1_content_blocks_2_custom_content_content":"Comprehensive, expertly curated database of up-to-date global consortia records.\r\n\r\nHelps with the understanding of the complex organizations of licensing consortia. A comprehensive database with records for nearly 350 licensing consortia worldwide, Ringgold Consortium Directory supports publishers in strategic sales planning and empowers them to easily craft individual offers.","solutions_modules_1_content_blocks_2_custom_content_link":"","solutions_modules_1_content_blocks_2_custom_content_open_link_in_new_window":0,"solutions_modules_1_content_blocks_2_custom_content":"","solutions_modules_1_content_blocks_2_button_link":"","solutions_modules_1_content_blocks_2_button_link_text":"","solutions_modules_1_content_blocks_2_button_open_link_in_new_window":0,"solutions_modules_1_content_blocks_2_button":"","solutions_modules_1_content_blocks":3,"solutions_modules_1_alignment":"left","solutions_modules_1_image_container_height":64,"solutions_modules_1_background_color":"has-ringgold-white-gold-3-background-color","solutions_modules_1_slider_at_small_screen":0,"solutions_modules_2_background_color":"has-ringgold-white-gold-1-background-color","solutions_modules_3_kicker":"","solutions_modules_3_title":"What makes Ringgold unique","solutions_modules_3_title_link":"","solutions_modules_3_sections_0_content":"Organization persistent identifiers\r\n\r\n \tIncludes 770,000+ organization records, each with a unique Ringgold ID, rich hierarchies, and more than 30 descriptive metadata elements\r\n \tLink related organizations to form structured, granular hierarchies that reflect real-world relationships\r\n \tRobust geographic and demographic metadata\r\n\r\nUnparalleled data quality\r\n\r\n \tCCC has implemented dozens of different data quality metrics, analyzing completeness, consistency, currency, and redundancy to continually improve the quality of Ringgold data\r\n \tMachine-readable FAIR data and metadata\r\n\r\nData experts you can trust\r\n\r\n \tRinggold Organization data is curated, maintained, and quality controlled by a team of data management and language experts with over 200 years' collective experience\r\n \tThe data team has manually audited over 1.69 million distinct client organizational records, matching them to Ringgold records, since 2011\r\n\r\n","solutions_modules_3_sections_0_content_width":"one-whole","solutions_modules_3_sections_0_desktop_column_width":"default","solutions_modules_3_sections":1,"solutions_modules_3_vertical_alignment":"are-vertically-aligned-top","solutions_modules_3_background_color":"has-ringgold-white-gold-2-background-color","solutions_modules_3_section_padding":"stage--has-default-padding","solutions_modules_4_title":"Client success stories","solutions_modules_4_slides_0_logo":55345,"solutions_modules_4_slides_0_title":"Kriyadocs Increases Workflow Efficiency and Metadata Quality for Publishers Using Ringgold IDs","solutions_modules_4_slides_0_content":"","solutions_modules_4_slides_0_link":"https:\/\/www.copyright.com\/resource-library\/case-studies\/kriyadocs-increases-workflow-efficiency-and-metadata-quality-for-publishers-using-ringgold-ids\/","solutions_modules_4_slides_0_background_image":55347,"solutions_modules_4_slides_1_logo":54380,"solutions_modules_4_slides_1_title":"Society for Neuroscience Leverages Ringgold Organizations to Standardize and Augment its Information Assets","solutions_modules_4_slides_1_content":"While SfN possessed a wealth of records and information on their members and constituent organizations, a lack of standardization and demographic data prevented it from employing its data as an asset.","solutions_modules_4_slides_1_link":"https:\/\/www.copyright.com\/resource-library\/case-studies\/the-society-for-neuroscience\/","solutions_modules_4_slides_1_background_image":54257,"solutions_modules_4_slides_2_logo":54382,"solutions_modules_4_slides_2_title":"The IET’s Inspec Analytics Research Intelligence Tool Leverages Ringgold Organizations to Standardize and Enhance Organizational Data","solutions_modules_4_slides_2_content":"Looking to better understand what information their customers needed to help them define their research goals and strategy, the IET team embarked on an effort to directly engage with their customer base.","solutions_modules_4_slides_2_link":"https:\/\/www.copyright.com\/resource-library\/case-studies\/iet\/","solutions_modules_4_slides_2_background_image":54256,"solutions_modules_4_slides":4,"solutions_modules_4_theme":"align-right","solutions_modules_4_background_color":"has-ringgold-white-gold-3-background-color","solutions_modules_5_title":"In the spotlight","solutions_modules_5_content_blocks_0_block_type":"custom","solutions_modules_5_content_blocks_0_custom_content_image":54329,"solutions_modules_5_content_blocks_0_custom_content_kicker":"Community","solutions_modules_5_content_blocks_0_custom_content_title":"Open Scholarly Publishing Solutions","solutions_modules_5_content_blocks_0_custom_content_content":"","solutions_modules_5_content_blocks_0_custom_content_link":"https:\/\/www.copyright.com\/ccc-pub-solutions\/","solutions_modules_5_content_blocks_0_custom_content_open_link_in_new_window":0,"solutions_modules_5_content_blocks_0_custom_content_links":"","solutions_modules_5_content_blocks_0_custom_content":"","solutions_modules_5_content_blocks_0_width":25,"solutions_modules_5_content_blocks_1_block_type":"custom","solutions_modules_5_content_blocks_1_custom_content_image":54328,"solutions_modules_5_content_blocks_1_custom_content_kicker":"Blog","solutions_modules_5_content_blocks_1_custom_content_title":"What Sets Ringgold Apart","solutions_modules_5_content_blocks_1_custom_content_content":"","solutions_modules_5_content_blocks_1_custom_content_link":"https:\/\/www.copyright.com\/blog\/what-sets-ringgold-solutions-apart\/","solutions_modules_5_content_blocks_1_custom_content_open_link_in_new_window":0,"solutions_modules_5_content_blocks_1_custom_content_links":"","solutions_modules_5_content_blocks_1_custom_content":"","solutions_modules_5_content_blocks_1_width":25,"solutions_modules_5_content_blocks_2_block_type":"custom","solutions_modules_5_content_blocks_2_custom_content_image":54327,"solutions_modules_5_content_blocks_2_custom_content_kicker":"Interactive Report","solutions_modules_5_content_blocks_2_custom_content_title":"The State of Scholarly Metadata","solutions_modules_5_content_blocks_2_custom_content_content":"CCC and Media Growth Strategies analyzed metadata management across the research lifecycle. Using interview insights, we developed an interactive visual report showing the impact of fragmented metadata and spotlighting initiatives improving its management.","solutions_modules_5_content_blocks_2_custom_content_link":"https:\/\/www.copyright.com\/stateofmetadata\/","solutions_modules_5_content_blocks_2_custom_content_open_link_in_new_window":0,"solutions_modules_5_content_blocks_2_custom_content_links":"","solutions_modules_5_content_blocks_2_custom_content":"","solutions_modules_5_content_blocks_2_width":50,"solutions_modules_5_content_blocks":3,"solutions_modules_5_background_color":"has-ringgold-white-gold-2-background-color","solutions_modules_6_kicker":"","solutions_modules_6_title":"More solutions for publishers","solutions_modules_6_content":"The CCC Scholarly Communications Suite supports publishers in\u2028automating their evolving publishing models with a suite of data-driven solutions.","solutions_modules_6_links_0_image":54384,"solutions_modules_6_links_0_link":"https:\/\/www.copyright.com\/solutions-rightslink-scientific-communications\/","solutions_modules_6_links_0_link_text":"RightsLink for Scientific Communications","solutions_modules_6_links_0_link_target":0,"solutions_modules_6_links_1_image":53739,"solutions_modules_6_links_1_link":"https:\/\/www.copyright.com\/solutions-oa-intelligence\/","solutions_modules_6_links_1_link_text":"OA Intelligence","solutions_modules_6_links_1_link_target":0,"solutions_modules_6_links_2_image":53754,"solutions_modules_6_links_2_link":"https:\/\/www.copyright.com\/solutions-rightslink-for-authors\/","solutions_modules_6_links_2_link_text":"RightsLink Author Services","solutions_modules_6_links_2_link_target":0,"solutions_modules_6_links":3,"solutions_modules_6_layout":"2-col","solutions_modules_6_background_color":"has-ringgold-white-gold-1-background-color","disable_webfonts":0,"featured_image_embedded_video":"","featured_image_embedded_videos_0_video":55002,"featured_image_embedded_videos_1_video":55003,"featured_image_embedded_videos":2,"hide_solution_type":0,"solutions_modules_4_slides_3_logo":54381,"solutions_modules_4_slides_3_title":"IEEE Uses Ringgold to Normalize and Disambiguate Organization Data to Strengthen the Integrity of Article Metadata","solutions_modules_4_slides_3_content":"IEEE needed a solution to disambiguate its data so it could map authors and documents to the correct organization and improve data-driven decision-making.","solutions_modules_4_slides_3_link":"https:\/\/www.copyright.com\/resource-library\/case-studies\/ieee-uses-ringgold-solutions-to-normalize-and-disambiguate-organization-data-to-strengthen-the-integrity-of-article-metadata\/","solutions_modules_4_slides_3_background_image":54258}},"postCountOnPage":1,"postCountTotal":1,"postID":40451};
