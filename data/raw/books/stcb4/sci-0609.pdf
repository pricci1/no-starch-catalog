 'asset_type': 'product sheet',
 'asset_topic': 'Services'
 });" target="_blank">Product sheet <svg aria-hidden="true" role="img" width="27" height="32" viewBox="0 0 27 32" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9.88344 17.9054C9.40687 17.5639 8.82393 17.404 8.23981 17.4545C7.68693 17.4465 7.13443 17.4878 6.58887 17.5781V23.2727H7.79612V21.2072C7.93412 21.2171 8.07268 21.2171 8.21068 21.2072C8.85218 21.2488 9.48362 21.0314 9.96344 20.6036C10.3018 20.2307 10.4796 19.7394 10.458 19.2363C10.4694 18.7302 10.2596 18.2442 9.88344 17.9054ZM8.4 20.2461C8.33418 20.2486 8.26825 20.2441 8.20337 20.2327L8.23975 20.2255C8.10443 20.2413 7.96775 20.2413 7.8325 20.2255V18.4945C7.99687 18.456 8.16556 18.4388 8.33431 18.4436C8.94525 18.4436 9.28706 18.7636 9.28706 19.2872C9.30687 19.797 8.90975 20.2263 8.4 20.2461Z"/><path d="M18.9092 0H2.90913C1.3025 0 0 1.30244 0 2.90907V29.0909C0 30.6976 1.30244 32 2.90907 32H23.2727C24.8794 32 26.1818 30.6976 26.1818 29.0909V8.00002L18.9092 0ZM24.7274 29.091C24.7274 29.8943 24.0761 30.5456 23.2728 30.5456H2.90913C2.10582 30.5456 1.45457 29.8943 1.45457 29.091V2.90907C1.45457 2.10575 2.10582 1.4545 2.90913 1.4545H16.0001V8.72727C16.0001 9.53058 16.6513 10.1818 17.4547 10.1818H24.7274V29.091H24.7274ZM17.4546 8.72727V1.45457H18.1818L24.7273 8.72733H17.4546V8.72727Z"/><path d="M14.8072 18.1164C14.1758 17.6387 13.3937 17.4038 12.6036 17.4545C12.0508 17.4507 11.4987 17.492 10.9526 17.5782V23.2727C11.4106 23.334 11.8724 23.3631 12.3345 23.36C13.2241 23.4258 14.1076 23.1675 14.8217 22.6327C15.4433 22.0204 15.7695 21.1691 15.7163 20.2982C15.7763 19.4679 15.439 18.6584 14.8072 18.1164ZM14.429 20.2982C14.4218 21.6727 13.7018 22.32 12.6036 22.3127V22.3055C12.4633 22.3195 12.322 22.3195 12.1818 22.3055V18.5164C12.3634 18.478 12.5489 18.461 12.7345 18.4655C13.616 18.4035 14.3808 19.0679 14.4427 19.9494C14.4508 20.0658 14.4463 20.1827 14.429 20.2982Z"/><path d="M16.771 23.2727H17.9928V20.9527H19.9274V19.8909H17.9928V18.5745H20.0656V17.5054H16.771V23.2727Z"/></svg></a></div><style>.wp-block-button--product-sheet .wp-block-button__link>svg {
                        fill: #d22600;
                        height: 24px;
                        width: 19px;
                        margin-left: 8px;
                      }
                      @media screen and (min-width: 870px) {
                        .wp-block-button--product-sheet .wp-block-button__link>svg {
                          height: 32px;
                          margin-left: 15px;
                          width: 26px;
                        }
                      }
                      .wp-block-button--product-sheet:hover  .wp-block-button__link>svg,
                      .wp-block-button--product-sheet:focus .wp-block-button__link>svg {
                        fill: #ffffff;
                      }</style></div><div class="solution-accordion"> <details class="solution-accordion__item" name="solution-accordion-40451"> <summary>Increase interoperability and efficiency with PIDs</summary><div class="solution-accordion__item-content"><p>Connect your systems, streamline publishing workflows, and eliminate data siloes with Ringgold&#8217;s market-leading persistent identifiers. Ringgold IDs link multiple datasets across systems, eliminating manual processes typically used by data teams when unifying multiple datasets. Ringgold also supports ISNI (an ISO standard – ISO 27729) as a bridge identifier to enable connections of different datasets in support of broader interoperability.</p></div> </details> <details class="solution-accordion__item" name="solution-accordion-40451"> <summary>Make confident decisions with high-quality data</summary><div class="solution-accordion__item-content"><p>Ringgold&#8217;s unparalleled data quality helps you fuel confident, data-driven strategic decisions and streamline reporting on research activity, funding, and organization affiliations. CCC has implemented dozens of different data quality metrics, analyzing completeness, consistency, currency, and redundancy, to continually improve the quality of Ringgold data.</p></div> </details> <details class="solution-accordion__item" name="solution-accordion-40451"> <summary>Save time on manual data cleanup</summary><div class="solution-accordion__item-content"><p>Free your teams from spending time on manual data cleanup with expertly curated, normalized, and enriched organization data delivered by CCC’s data management experts, who have over 200 years’ collective experience.</p></div> </details></div><style>.solution-accordion__item {
  background: rgba(36, 53, 100, 0.05);
  border-radius: 16px;
  margin-bottom: 18px;
}
.solution-accordion__item summary {
  background: #fff url(https://www.copyright.com/wp-content/themes/copyrightclearancecenter/assets/images/summary-marker-closed.svg) no-repeat 23px 50%;
  background-size: 20px;
  box-shadow: 0px 2px 2px 0px rgba(0, 95, 180, 0.25);
  border-radius: 16px 16px 0 0;
  font-family: 'Roboto Condensed', sans-serif;
  font-weight: 700;
  font-size: 20px;
  list-style: none;
  padding: 10px 10px 10px 54px;
}

@media (min-width: 1024px) {
  .solution-accordion__item summary {
    font-size: 1.375rem;
  }
}

.solution-accordion__item summary::-webkit-details-marker {
  display: none;
}

.solution-accordion__item[open] > summary {
  background-image: url(https://www.copyright.com/wp-content/themes/copyrightclearancecenter/assets/images/summary-marker-open.svg);
}

.solution-accordion__item-content {
  padding: 21px 25px;
}</style></div></div></div><div class="wrapper logo-wall" style="opacity: 70%"> <span class="logo-wall__title has-font-size-ccc-h7 has-font-weight-regular">Trusted by</span><ul class="logo-wall__logos list-bare"><li> <img width="294" height="96" src="https://www.copyright.com/wp-content/uploads/2025/12/sfn-society-for-neuorscience_logo_black.png" class="attachment-large size-large" alt="" decoding="async" srcset="https://www.copyright.com/wp-content/uploads/2025/12/sfn-society-for-neuorscience_logo_black.png 294w, https://www.copyright.com/wp-content/uploads/2025/12/sfn-society-for-neuorscience_logo_black-210x69.png 210w, https://www.copyright.com/wp-content/uploads/2025/12/sfn-society-for-neuorscience_logo_black-111x36.png 111w, https://www.copyright.com/wp-content/uploads/2025/12/sfn-society-for-neuorscience_logo_black-180x59.png 180w" sizes="(max-width: 294px) 100vw, 294px" /></li><li> <img width="130" height="64" src="https://www.copyright.com/wp-content/uploads/2025/12/IET_logo_black.png" class="attachment-large size-large" alt="" decoding="async" srcset="https://www.copyright.com/wp-content/uploads/2025/12/IET_logo_black.png 130w, https://www.copyright.com/wp-content/uploads/2025/12/IET_logo_black-111x55.png 111w" sizes="(max-width: 130px) 100vw, 130px" /></li><li> <img width="240" height="64" src="https://www.copyright.com/wp-content/uploads/2025/12/annual-reviews_logo_black.png" class="attachment-large size-large" alt="" decoding="async" srcset="https://www.copyright.com/wp-content/uploads/2025/12/annual-reviews_logo_black.png 240w, https://www.copyright.com/wp-content/uploads/2025/12/annual-reviews_logo_black-210x56.png 210w, https://www.copyright.com/wp-content/uploads/2025/12/annual-reviews_logo_black-111x30.png 111w, https://www.copyright.com/wp-content/uploads/2025/12/annual-reviews_logo_black-180x48.png 180w" sizes="(max-width: 240px) 100vw, 240px" /></li><li> <img width="220" height="64" src="https://www.copyright.com/wp-content/uploads/2025/12/IEEEE_logo_black.png" class="attachment-large size-large" alt="" decoding="async" loading="lazy" srcset="https://www.copyright.com/wp-content/uploads/2025/12/IEEEE_logo_black.png 220w, https://www.copyright.com/wp-content/uploads/2025/12/IEEEE_logo_black-210x61.png 210w, https://www.copyright.com/wp-content/uploads/2025/12/IEEEE_logo_black-111x32.png 111w, https://www.copyright.com/wp-content/uploads/2025/12/IEEEE_logo_black-180x52.png 180w" sizes="auto, (max-width: 220px) 100vw, 220px" /></li></ul></div><style>.logo-wall {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: 20px;
    padding-bottom: 18px;
  }

  .logo-wall__logos {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: space-around;
    flex: 1;
    gap: 10px;
  }

  .logo-wall__logos img {
    height: auto;
    width: 45px;
  }

  @media (min-width: 1024px) {
    .logo-wall {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .logo-wall__logos img {
      width: 100px;
    }
  }</style></div></div></div><style>@media screen and (min-width: 1080px) {
        .stage--1.stage--hero {
          margin-top: -23px;
          padding-top: 23px;
        }
      }</style><div class="stage stage--reduced-padding stage--open-content has-background-color has-ringgold-white-gold-1-background-color"><div class="wrapper"><div class="row clearfix row--flex row--flex-wrap row--flex-center"><div class="col col--1 palm-one-whole lap-one-whole desk-one-half"><div class="entry-content seven-eighths"><h3><img loading="lazy" decoding="async" src="https://www.copyright.com/wp-content/uploads/2025/11/solution-ringgold-organizations-with-icon@2x.png" alt="Ringgold Organizations" width="519" height="68" /></h3><h4 class="has-font-size-ccc-h6">Trusted data about global organizations engaged in scholarly research</h4><p>Ringgold Organizations provides publishers and service providers trusted, high-quality data to fuel confident, strategic decisions, streamline reporting, and support interoperability with an expertly curated database of global organizations that fund, create, and use scholarly research.</p><div class="wp-block-button has-pseudo-icon has-icon-pdf"><a class="wp-block-button__link has-shadow" href="https://www.copyright.com/wp-content/uploads/2025/12/Ringgold-Organizations-overview-sheet.pdf" target="_blank" rel="noopener">Product sheet</a></div></div></div><div class="col col--2 palm-one-whole lap-one-whole desk-one-half"><div class="entry-content seven-eighths"><p><img loading="lazy" decoding="async" src="https://www.copyright.com/wp-content/uploads/2025/11/get-your-ringgold-id-isni-id.png" alt="Get your Ringgold ID or ISNI ID" width="365" height="56" /></p><p>Persistent identifiers (PIDs) uniquely identify your organization.  Find your organization&#8217;s Ringgold ID or ISNI ID using our complimentary lookup service, or request a new ID.</p><div class="wp-block-button has-text-align-right" style="display: block; text-align: right;"><a class="wp-block-button__link has-shadow" href="https://www.copyright.com/solutions-ringgold/get-id/">Get Your Organization ID</a></div></div></div></div></div></div><div class="stage how-can-we-help how-can-we-help--columns has-background-color  has-ringgold-white-gold-3-background-color"><div class="wrapper"><header class="spacing--bottom--double"><h2 class="stage__title spacing--bottom--half  lap-and-up-one-whole" id="additional-services">Additional Services</h2></header><div class="row clearfix how-can-we-help--3"><div class="col palm-one-whole lap-one-third desk-one-third has-text-align-left how-can-we-help--column__item how-can-we-help--column__item--1"> <a href="https://www.copyright.com/wp-content/uploads/2024/03/Ringgold-Audit-Service.pdf" target="_blank" rel="nofollow noopener" onClick="dataLayer.push({ 'event': 'interactionEvent', 'event_name': 'page_section_click', 'click_text': 'Ringgold Audit Service', 'click_url': 'https://www.copyright.com/wp-content/uploads/2024/03/Ringgold-Audit-Service.pdf', 'location': 'Additional Services' });"><div class="column-list__item-icon" style="height: 64px"><img width="808" height="808" src="https://www.copyright.com/wp-content/uploads/2025/11/ringgold-consortium-directory-64x64-1.svg" class="attachment-large size-large" alt="" decoding="async" loading="lazy" /></div><h3 class="has-font-size-ccc-h4 has-font-weight-light column-list__item-title">Ringgold Audit Service</h3> </a><div class="column-list__item-content has-text-align-left"><p><strong>Normalize and enrich your data.</strong></p><p>Leverage trusted data experts to help you normalize and enrich your data to create a clean, comprehensive set of global organization data.</p><div class="spacing--top wp-block-button has-pseudo-icon has-icon-pdf"><a class="wp-block-button__link has-shadow" href="https://www.copyright.com/wp-content/uploads/2024/03/Ringgold-Audit-Service.pdf" target="_blank" rel="noopener">Product sheet</a></div></div></div><div class="col palm-one-whole lap-one-third desk-one-third has-text-align-left how-can-we-help--column__item how-can-we-help--column__item--2"><div class="column-list__item-icon" style="height: 64px"><img width="808" height="808" src="https://www.copyright.com/wp-content/uploads/2025/11/ringgold-validate-service-64x64-1.svg" class="attachment-large size-large" alt="" decoding="async" loading="lazy" /></div><h3 class="has-font-size-ccc-h4 has-font-weight-light column-list__item-title">Ringgold Validate Service</h3><div class="column-list__item-content has-text-align-left"><p><strong>Create new Ringgold IDs on demand.</strong></p><p>Enables Ringgold Organizations users to immediately generate new Ringgold IDs for organizations not currently held in our database.</p></div></div><div class="col palm-one-whole lap-one-third desk-one-third has-text-align-left how-can-we-help--column__item how-can-we-help--column__item--3"><div class="column-list__item-icon" style="height: 64px"><img width="808" height="808" src="https://www.copyright.com/wp-content/uploads/2025/11/ringgold-audit-service-64x64-1.svg" class="attachment-large size-large" alt="" decoding="async" loading="lazy" /></div><h3 class="has-font-size-ccc-h4 has-font-weight-light column-list__item-title">Ringgold Consortium Directory</h3><div class="column-list__item-content has-text-align-left"><p><strong>Comprehensive, expertly curated database of up-to-date global consortia records.</strong></p><p>Helps with the understanding of the complex organizations of licensing consortia. A comprehensive database with records for nearly 350 licensing consortia worldwide, Ringgold Consortium Directory supports publishers in strategic sales planning and empowers them to easily craft individual offers.</p></div></div></div></div></div><div class="stage stage--by-the-numbers  has-ringgold-white-gold-1-background-color"><div class="wrapper"><h2 class="stage__title has-font-weight-semi-bold">Ringgold by the numbers</h2><div class="by-the-number-cards has-white-color"><div class="by-the-number-card has-text-align-center"><p><strong class="by-the-number-card__figure">770,000<span class="has-huge-font-size"><span class="by-the-number-card__plus">+</span></span></strong><br>organization records, each with a unique Ringgold ID, rich hierarchies, and over 30 descriptive metadata elements</p></div><div class="by-the-number-card has-text-align-center"><p>Used by <br /> <strong class="by-the-number-card__figure">80 <span class="has-large-font-size"></strong><br>leading publishers, service providers, and funders</p></div><div class="by-the-number-card has-text-align-center"><p><strong class="by-the-number-card__figure">99.9%<span class="has-huge-font-size"><span class="by-the-number-card__plus">+</span></span></strong><br>of Ringgold ID's have a corresponding ISNI ID</p></div><div class="by-the-number-card has-text-align-center"><p><strong class="by-the-number-card__figure">32,300 <span class="has-huge-font-size"><span class="by-the-number-card__plus">+</span></span></strong><br>funder records</p></div><div class="by-the-number-card has-text-align-center"><p><strong class="by-the-number-card__figure">139,000 <span class="has-huge-font-size"><span class="by-the-number-card__plus">+</span></span></strong><br>new records added in the past 12 months</p></div><div class="by-the-number-card has-text-align-center"><p><strong class="by-the-number-card__figure">254,000 <span class="has-huge-font-size"><span class="by-the-number-card__plus">+</span></span></strong><br>records updated in the last 12 months</p></div></div></div></div><div class="stage stage--reduced-padding stage--open-content has-background-color has-ringgold-white-gold-2-background-color"><div class="wrapper"><header><h2 class="stage__title" id="what-makes-ringgold-unique">What makes Ringgold unique</h2></header><div class="row clearfix row--no-flex"><div class="col col--1 palm-one-whole lap-one-whole desk-one-whole"><div class="entry-content one-whole"> <details> <summary>Organization persistent identifiers</summary><ul><li>Includes 770,000+ organization records, each with a unique Ringgold ID, rich hierarchies, and more than 30 descriptive metadata elements</li><li>Link related organizations to form structured, granular hierarchies that reflect real-world relationships</li><li>Robust geographic and demographic metadata</li></ul> </details> <details> <summary>Unparalleled data quality</summary><ul><li>CCC has implemented dozens of different data quality metrics, analyzing completeness, consistency, currency, and redundancy to continually improve the quality of Ringgold data</li><li>Machine-readable FAIR data and metadata</li></ul> </details> <details> <summary>Data experts you can trust</summary><ul><li>Ringgold Organization data is curated, maintained, and quality controlled by a team of data management and language experts with over 200 years&#8217; collective experience</li><li>The data team has manually audited over 1.69 million distinct client organizational records, matching them to Ringgold records, since 2011</li></ul> </details></div></div></div></div></div><div class="stage stage--reduced-padding stage--case-study-slider has-background-color has-ringgold-white-gold-3-background-color"><div class="wrapper"><h2 class="has-font-size-ccc-h4 spacing--bottom has-text-align-center" id="client-success-stories">Client success stories</h2><div class="case-study-slider  owl-carousel  case-study-theme case-study-theme--align-right" id="case-study-slider-998331895"><div class="item case-study-slider__slide" style="background-image: url(https://www.copyright.com/wp-content/uploads/2026/04/ringgold-case-study-slider-kriyadocs-1024x414.jpg); background-size: cover; background-repeat: no-repeat;"><div class="case-study-slider__slide-content-container"><figure class="case-study-slider__slide-logo"> <img width="808" height="180" src="https://www.copyright.com/wp-content/uploads/2026/04/kriyadocs-logo.svg" class="attachment-large size-large" alt="Kriyadocs" decoding="async" loading="lazy" /></figure><div class="case-study-slider__slide-text"><h3 class="case-study-slider__slide-title has-font-size-ccc-h6 has-font-weight-bold" style="min-height: 55px; margin-bottom: 1rem">Kriyadocs Increases Workflow Efficiency and Metadata Quality for Publishers Using Ringgold IDs</h3></div><div class="wp-block-button is-style-fill"><a class="wp-block-button__link case-study-slider__link has-background-color has-transparent-background-color has-text-color has-white-color" href="https://www.copyright.com/resource-library/case-studies/kriyadocs-increases-workflow-efficiency-and-metadata-quality-for-publishers-using-ringgold-ids/">Read case study</a></div></div></div><div class="item case-study-slider__slide" style="background-image: url(https://www.copyright.com/wp-content/uploads/2025/11/ringgold-case-study-slider-sfn-1024x414.jpg); background-size: cover; background-repeat: no-repeat;"><div class="case-study-slider__slide-content-container"><figure class="case-study-slider__slide-logo"> <img width="808" height="324" src="https://www.copyright.com/wp-content/uploads/2025/12/SFN_logo_white.svg" class="attachment-large size-large" alt="" decoding="async" loading="lazy" /></figure><div class="case-study-slider__slide-text"><h3 class="case-study-slider__slide-title has-font-size-ccc-h6 has-font-weight-bold" style="min-height: 55px; margin-bottom: 1rem">Society for Neuroscience Leverages Ringgold Organizations to Standardize and Augment its Information Assets</h3><div class="case-study-slider__slide-content has-font-family-body spacing--bottom"><p>While SfN possessed a wealth of records and information on their members and constituent organizations, a lack of standardization and demographic data prevented it from employing its data as an asset.</p></div></div><div class="wp-block-button is-style-fill"><a class="wp-block-button__link case-study-slider__link has-background-color has-transparent-background-color has-text-color has-white-color" href="https://www.copyright.com/resource-library/case-studies/the-society-for-neuroscience/">Read case study</a></div></div></div><div class="item case-study-slider__slide" style="background-image: url(https://www.copyright.com/wp-content/uploads/2025/11/ringgold-case-study-slider-iet-1024x414.jpg); background-size: cover; background-repeat: no-repeat;"><div class="case-study-slider__slide-content-container"><figure class="case-study-slider__slide-logo"> <img width="808" height="324" src="https://www.copyright.com/wp-content/uploads/2025/12/IET_logo_white.svg" class="attachment-large size-large" alt="" decoding="async" loading="lazy" /></figure><div class="case-study-slider__slide-text"><h3 class="case-study-slider__slide-title has-font-size-ccc-h6 has-font-weight-bold" style="min-height: 55px; margin-bottom: 1rem">The IET’s Inspec Analytics Research Intelligence Tool Leverages Ringgold Organizations to Standardize and Enhance Organizational Data</h3><div class="case-study-slider__slide-content has-font-family-body spacing--bottom"><p>Looking to better understand what information their customers needed to help them define their research goals and strategy, the IET team embarked on an effort to directly engage with their customer base.</p></div></div><div class="wp-block-button is-style-fill"><a class="wp-block-button__link case-study-slider__link has-background-color has-transparent-background-color has-text-color has-white-color" href="https://www.copyright.com/resource-library/case-studies/iet/">Read case study</a></div></div></div><div class="item case-study-slider__slide" style="background-image: url(https://www.copyright.com/wp-content/uploads/2025/11/ringgold-case-study-slider-ieee-1024x414.jpg); background-size: cover; background-repeat: no-repeat;"><div class="case-study-slider__slide-content-container"><figure class="case-study-slider__slide-logo"> <img width="808" height="324" src="https://www.copyright.com/wp-content/uploads/2025/12/IEEE_logo_white.svg" class="attachment-large size-large" alt="" decoding="async" loading="lazy" /></figure><div class="case-study-slider__slide-text"><h3 class="case-study-slider__slide-title has-font-size-ccc-h6 has-font-weight-bold" style="min-height: 55px; margin-bottom: 1rem">IEEE Uses Ringgold to Normalize and Disambiguate Organization Data to Strengthen the Integrity of Article Metadata</h3><div class="case-study-slider__slide-content has-font-family-body spacing--bottom"><p>IEEE needed a solution to disambiguate its data so it could map authors and documents to the correct organization and improve data-driven decision-making.</p></div></div><div class="wp-block-button is-style-fill"><a class="wp-block-button__link case-study-slider__link has-background-color has-transparent-background-color has-text-color has-white-color" href="https://www.copyright.com/resource-library/case-studies/ieee-uses-ringgold-solutions-to-normalize-and-disambiguate-organization-data-to-strengthen-the-integrity-of-article-metadata/">Read case study</a></div></div></div></div><div class="owl-controls"> <button type="button" role="presentation" class="case-study-slider__prev"><svg aria-hidden="true" width="20" height="17" viewBox="0 0 20 17" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0.319676 9.09646L7.54238 16.3193C7.74856 16.5255 8.02335 16.6387 8.31636 16.6387C8.60969 16.6387 8.88432 16.5253 9.0905 16.3193L9.74626 15.6634C9.95228 15.4575 10.0658 15.1826 10.0658 14.8894C10.0658 14.5964 9.95228 14.3122 9.74626 14.1063L5.53264 9.88344L18.9195 9.88344C19.5231 9.88344 20 9.41093 20 8.80719L20 7.87988C20 7.27615 19.5231 6.75599 18.9195 6.75599L5.48484 6.75599L9.7461 2.50952C9.95212 2.30334 10.0656 2.03586 10.0656 1.7427C10.0656 1.44985 9.95212 1.17847 9.7461 0.97246L9.09034 0.318645C8.88416 0.112468 8.60953 0.00010963 8.3162 0.000109605C8.02319 0.000109579 7.7484 0.113929 7.54222 0.320107L0.319512 7.54281C0.112847 7.74964 -0.00080987 8.02573 4.54201e-06 8.31923C-0.00064589 8.6137 0.112847 8.88995 0.319676 9.09646Z"></path></svg><span class="screen-reader-text">Previous slide</span></button><div id="case-study-slider-dots" class="owl-dots"></div> <button type="button" role="presentation" class="case-study-slider__next"><svg aria-hidden="true" width="20" height="17" viewBox="0 0 20 17" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M19.6803 7.54221L12.4576 0.319347C12.2514 0.11317 11.9766 0 11.6836 0C11.3903 0 11.1157 0.113332 10.9095 0.319347L10.2537 0.975276C10.0477 1.18113 9.93423 1.45609 9.93423 1.74925C9.93423 2.04226 10.0477 2.32648 10.2537 2.53234L14.4674 6.75523H1.08048C0.476907 6.75523 0 7.22775 0 7.83148V8.75879C0 9.36252 0.476907 9.88268 1.08048 9.88268H14.5152L10.2539 14.1292C10.0479 14.3353 9.93439 14.6028 9.93439 14.896C9.93439 15.1888 10.0479 15.4602 10.2539 15.6662L10.9097 16.32C11.1158 16.5262 11.3905 16.6386 11.6838 16.6386C11.9768 16.6386 12.2516 16.5247 12.4578 16.3186L19.6805 9.09586C19.8872 8.88903 20.0008 8.61294 20 8.31944C20.0006 8.02497 19.8872 7.74872 19.6803 7.54221Z"></path></svg><span class="screen-reader-text">Next slide</span></button></div></div> <script defer src="data:text/javascript;base64,"></script> <style>.case-study-theme--align-right .case-study-slider__link.wp-block-button__link {
    background: transparent;
    border-color: #88EBFF;
  }

  .case-study-theme--align-left .case-study-slider__link.wp-block-button__link {
    border-color: #005FB4;
  }

  .case-study-theme--align-right .case-study-slider__link.wp-block-button__link:hover,
  .case-study-theme--align-right .case-study-slider__link.wp-block-button__link:focus,
  .case-study-theme--align-left .case-study-slider__link.wp-block-button__link:hover,
  .case-study-theme--align-left .case-study-slider__link.wp-block-button__link:focus {
    background: #00a9ed;
    border-color: #00a9ed;
  }

  .case-study-theme:not(.case-study-theme--align-left) .owl-stage-outer {
    border-radius: 24px;
    box-shadow: 4px 8px 16px 0px rgba(0, 0, 0, 0.2);
  }

  .owl-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 24px;
  }

  .owl-controls button {
    appearance: none;
    -webkit-appearance: none;
  }

  .owl-controls button.case-study-slider__next,
  .owl-controls button.case-study-slider__prev {
    background-color: #fff;
    border: 2px solid #005FB4;
    border-radius: 80px;
    display: none;
    height: 48px;
    padding: 13px 0;
    width: 48px;
  }

  .owl-controls button.case-study-slider__next svg,
  .owl-controls button.case-study-slider__prev svg {
    fill: #005FB4;
  }

  .owl-controls button.case-study-slider__next:hover,
  .owl-controls button.case-study-slider__next:focus,
  .owl-controls button.case-study-slider__prev:hover,
  .owl-controls button.case-study-slider__prev:focus {
    background-color: #00A9ED;
    border-color: #00A9ED;
  }

  .owl-controls button.case-study-slider__next:hover svg,
  .owl-controls button.case-study-slider__next:focus svg,
  .owl-controls button.case-study-slider__prev:hover svg,
  .owl-controls button.case-study-slider__prev:focus svg {
    fill: #fff;
  }


  .owl-controls button.owl-dot {
    background-color: #94A5A6;
    border: none;
    border-radius: 48px;
    height: 12px;
    margin: 0 4px;
    width: 40px;
  }

  .owl-controls button.owl-dot:hover,
  .owl-controls button.owl-dot:focus {
    background-color: #00A9ED;
  }

  .owl-controls .owl-dots {
    text-align: center;
  }

  .owl-controls button.owl-dot.active {
    background-color: #005FB4;
  }

  .case-study-slider__slide-content-container {
    background: rgba(36, 53, 100, 0.85);
    border-radius: 24px;
    padding: 51px 24px 24px;
    position: relative;
  }

  .case-study-slider__slide {
    background-color: #00326E;
    border-radius: 24px;
    display: flex;
    min-height: 495px;
  }

  
  .case-study-slider__slide-title {
    color: rgba(136, 235, 255, 1);
  }

  .case-study-slider__slide-content {
    color: #fff;
  }

  .case-study-slider__slide-content > * + * {
    margin-top: 16px;
  }

  
  .case-study-slider__slide-logo {
    margin-bottom: 30px;
  }

  .owl-item .case-study-slider__slide-logo img {
    height: 47px;
    width: auto;
  }

  @media (max-width: 1023px) {
    .case-study-theme--align-left .owl-controls button.case-study-slider__next,
    .case-study-theme--align-left .owl-controls button.case-study-slider__prev {
      display: none;
    }
  }

  @media (min-width: 1024px) {
    .owl-controls button.case-study-slider__next,
    .owl-controls button.case-study-slider__prev {
      display: block;
    }

    .owl-controls .owl-dots {
      margin-left: 22px;
      margin-right: 22px;
    }

    .owl-controls button.owl-dot {
      width: 48px;
    }

    .case-study-slider__slide-content-container {
      border-radius: 0 24px 24px 0;
      margin-left: auto;
      padding: 41px 35px 20px 20px;
      width: 33.333%;
    }

    .case-study-theme--align-left .case-study-slider__slide-content-container {
      background: transparent;
      display: flex;
      flex-direction: column;
      border-radius: 24px;
      margin-left: initial;
      width: 100%;
      z-index: 30;
    }

    .case-study-theme--align-left .case-study-slider__slide {
      width: 808px;
    }

    
    .case-study-slider__slide-content-container::before {
      background: linear-gradient(270deg, rgba(36, 53, 100, 85%) 0%, rgba(36, 53, 100, 0) 100%);
      content: '';
      position: absolute;
      right: 100%;
      top: 0;
      width: 88%;
      height: 100%;
