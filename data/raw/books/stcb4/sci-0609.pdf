content/plugins/*","/wp-content/themes/copyrightclearancecenter/*","/*\\?(.+)"]}},{"not":{"selector_matches":"a[rel~=\"nofollow\"]"}},{"not":{"selector_matches":".no-prefetch, .no-prefetch a"}}]},"eagerness":"conservative"}]}</script> <script defer src="data:text/javascript;base64,"></script>  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KTCVKZX" height="0" width="0" style="display:none;visibility:hidden" aria-hidden="true"></iframe></noscript> <script defer type="text/javascript" src="https://www.copyright.com/wp-content/cache/autoptimize/1/js/autoptimize_single_416f52248a7f5b988d66f1ea80a196ce.js?ver=1.22.3" id="gtm4wp-form-move-tracker-js"></script> <script defer type="text/javascript" src="https://www.copyright.com/wp-content/cache/autoptimize/1/js/autoptimize_single_798956479cce0265eb43b3566bd388c4.js" id="copyrightclearancecenter-search-js"></script> <script defer type="text/javascript" src="https://www.copyright.com/wp-content/cache/autoptimize/1/js/autoptimize_single_2d79c98ddd3e23716b2ceab6bf21f85f.js?ver=1.0" id="copyrightclearancecenter-slide-menu-js"></script> <script defer id="copyrightclearancecenter-slide-menu-js-after" src="data:text/javascript;base64,"></script> <script defer type="text/javascript" src="https://www.copyright.com/wp-content/themes/copyrightclearancecenter/assets/js/plugins/magnific-popup.min.js?ver=1.1.0" id="copyrightclearancecenter-modal-js"></script> <script defer type="text/javascript" src="https://www.copyright.com/wp-content/themes/copyrightclearancecenter/assets/js/plugins/van11y-accessible-simple-tooltip-aria.min.js?ver=3.0.0" id="van11y-tooltip-js"></script> <script defer type="text/javascript" src="https://www.copyright.com/wp-content/themes/copyrightclearancecenter/assets/js/min/scripts-min.js?ver=1778632558" id="copyrightclearancecenter-scripts-js"></script> <script defer type="text/javascript" src="https://www.copyright.com/wp-content/cache/autoptimize/1/js/autoptimize_single_9793694bc1a67d416db9b7b88ad2f581.js?ver=1.12" id="copyrightclearancecenter-navigation-js"></script> <script defer type="text/javascript" src="https://www.copyright.com/wp-content/cache/autoptimize/1/js/autoptimize_single_20b3b806e556954dbacaf87d635d399d.js?ver=3.3.7" id="page-links-to-js"></script> <script>const FONT_GROUP_ID = 'C0002';

  // Make these global so mtiFontTrackingCode.js can read them
  window.MTUserId = 'ff0c0e5f-92ad-4beb-9788-703974284501';
  window.MTFontIds = ['6018010','6018022','6018051','6018059','6018069'];

  function userHasInteractedBefore() {
    return /(?:^|;\s*)OptanonAlertBoxClosed=/.test(document.cookie);
  }

  function getActiveGroupsString() {
    // OneTrust uses this string in many deployments
    return (window.OnetrustActiveGroups || window.OptanonActiveGroups || '').toString();
  }

  function hasOnetrustGroupEnabled(groupId, activeGroupsFromEvent) {
    // 1) Prefer event.detail (array), when provided
    if (Array.isArray(activeGroupsFromEvent) && activeGroupsFromEvent.length) {
      return activeGroupsFromEvent.indexOf(groupId) !== -1;
    }
    // 2) Fallback to global string (available after OneTrust init)
    const dl = getActiveGroupsString();
    return dl.indexOf(groupId) !== -1;
  }

  function loadFontsOnce() {
    if (window.__fontsLoaded) return;
    window.__fontsLoaded = true;

    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://www.copyright.com/wp-content/themes/copyrightclearancecenter/assets/css/webfonts.css';
    document.head.appendChild(link);

    const mtTracking = document.createElement('script');
    mtTracking.async = true;
    mtTracking.src = 'https://www.copyright.com/wp-content/themes/copyrightclearancecenter/assets/js/mtiFontTrackingCode.js';
    (document.head || document.body).appendChild(mtTracking);
  }

  // Centralized decision
  function maybeLoadFonts(activeGroupsFromEvent) {
    // Require user interaction at least once (your policy choice)
    if (!userHasInteractedBefore()) return;

    if (hasOnetrustGroupEnabled(FONT_GROUP_ID, activeGroupsFromEvent)) {
      loadFontsOnce();
    }
  }

  // 1) Handle updates when user accepts/changes preferences
  window.addEventListener('OneTrustGroupsUpdated', function (event) {
    // When this fires due to an actual preference change, cookies are usually already set.
    const activeGroups = event && event.detail ? event.detail : null;
    maybeLoadFonts(activeGroups);
  });

  // 2) Handle returning users when OneTrust loads later via GTM:
  // Poll briefly for OneTrust to initialize and set its globals, then decide once.
  (function waitForOneTrustInit() {
    const start = Date.now();
    const timeoutMs = 8000; // stop after 8s
    const intervalMs = 100;

    const t = setInterval(function () {
      const dl = getActiveGroupsString();

      // Once OneTrust is initialized, this string is usually non-empty
      if (dl && dl.length) {
        clearInterval(t);
        maybeLoadFonts(null);
        return;
      }

      if (Date.now() - start > timeoutMs) {
        clearInterval(t);
      }
    }, intervalMs);
  })();</script> <svg style="position: absolute; width: 0; height: 0; overflow: hidden;" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <defs> <symbol id="icon-arrow-left" viewBox="0 0 11 18"><path d="M8.93671 16.7046L9.70704 15.9302C9.96026 15.6619 10.0869 15.3485 10.0869 14.9907C10.0869 14.6256 9.96026 14.3159 9.70704 14.0612L4.7158 9.04238L9.70689 4.02361C9.96012 3.76891 10.0868 3.45915 10.0868 3.09416C10.0868 2.73623 9.96012 2.42289 9.70689 2.15452L8.93656 1.39033C8.67654 1.12868 8.36493 0.997925 8.00203 0.997925C7.63237 0.997925 7.32429 1.12882 7.07786 1.39029L0.392336 8.1129C0.132274 8.36084 0.0021359 8.67048 0.00213588 9.04234C0.00213586 9.40722 0.132238 9.72052 0.392335 9.98192L7.07786 16.7046C7.33123 16.9593 7.63928 17.0868 8.00203 17.0868C8.35817 17.0868 8.6696 16.9593 8.93671 16.7046Z"/></symbol> <symbol id="icon-arrow-right" viewBox="0 0 11 18"><path d="M1.15225 1.38012L0.381921 2.15447C0.128694 2.42282 0.00204405 2.73622 0.00204407 3.09398C0.00204408 3.45911 0.128694 3.76879 0.381921 4.02353L5.37316 9.04234L0.382065 14.0611C0.128838 14.3158 0.00218864 14.6256 0.00218866 14.9906C0.00218868 15.3485 0.128838 15.6618 0.382066 15.9302L1.15239 16.6944C1.41242 16.956 1.72403 17.0868 2.08693 17.0868C2.45659 17.0868 2.76467 16.9559 3.0111 16.6944L9.69662 9.97182C9.95668 9.72388 10.0868 9.41423 10.0868 9.04237C10.0868 8.6775 9.95672 8.36419 9.69662 8.1028L3.0111 1.38016C2.75773 1.12542 2.44968 0.997955 2.08693 0.997955C1.73079 0.997919 1.41936 1.12538 1.15225 1.38012Z"/></symbol> <symbol id="icon-badge" viewBox="0 0 512 512"><g><path d="m368.722 169.479c-8.904-7.5-20.211-11.084-31.794-10.087-11.6.994-22.116 6.446-29.612 15.351l-65.123 77.336-31.43-32.686c-16.654-17.323-44.299-17.865-61.62-1.209-8.392 8.067-13.138 18.92-13.366 30.559-.229 11.639 4.09 22.67 12.158 31.061l64.989 67.591c8.172 8.5 19.621 13.375 31.413 13.375.475 0 .95-.009 1.437-.024 12.331-.406 23.958-6.051 31.9-15.485l96.312-114.375c7.499-8.903 11.081-20