object-page"><a href="https://www.copyright.com/get-help/" class="menu-link main-menu-link">Get help</a></li><li id="nav-menu-item-50313" class="log-in-menu menu-item menu-item-type-custom menu-item-object-custom menu-item-has-children"><a href="#" class="menu-link main-menu-link">Log in</a><ul class="sub-menu"><li id="nav-menu-item-50314" class="marketplace_click menu-item menu-item-type-custom menu-item-object-custom"><a target="_blank" href="https://sso.copyright.com/cas/login?allow_corporate_sign_in=true&amp;lang=EN&amp;service=https://marketplace.copyright.com/rs-ui-web/verify_ticket&amp;register=https://marketplace.copyright.com/rs-ui-web/mp/registration" class="menu-link sub-menu-link"><span class="js-simple-tooltip" data-simpletooltip-text="Get copyright permissions, content and reprints">CCC Marketplace</span></a></li><li id="nav-menu-item-50315" class="menu-item menu-item-type-custom menu-item-object-custom"><a target="_blank" href="https://www.rightfind.com/" class="menu-link sub-menu-link"><span class="js-simple-tooltip" data-simpletooltip-text="Search with fast secure access to STM content">RightFind Enterprise</span></a></li><li id="nav-menu-item-50316" class="menu-item menu-item-type-custom menu-item-object-custom"><a target="_blank" href="https://rightfindsuite.copyright.com/rfn-app/" class="menu-link sub-menu-link"><span class="js-simple-tooltip" data-simpletooltip-text="Search across multiple types of STM content">RightFind Navigate</span></a></li><li id="nav-menu-item-50317" class="menu-item menu-item-type-custom menu-item-object-custom"><a target="_blank" href="https://sso.copyright.com/cas/login?service=https%3A%2F%2Fs100.copyright.com%2FMyAccount%2F" class="menu-link sub-menu-link"><span class="js-simple-tooltip" data-simpletooltip-text="Manage RightsLink Permissions orders and invoices at MyAccount">RightsLink Permissions</span></a></li><li id="nav-menu-item-50318" class="menu-item menu-item-type-custom menu-item-object-custom"><a target="_blank" href="https://www.copyright.com/manage-your-account/what-do-you-need-to-do-today/" class="menu-link sub-menu-link"><span class="js-simple-tooltip" data-simpletooltip-text="Visit RightsCentral, Pub Portal, RightsLink Pub Admin">Rightsholder Accounts</span></a></li><li id="nav-menu-item-50319" class="menu-item menu-item-type-custom menu-item-object-custom"><a target="_blank" href="https://ringgold-organizations.copyright.com/" class="menu-link sub-menu-link"><span class="js-simple-tooltip" data-simpletooltip-text="Access an expertly curated database of organizations">Ringgold Organizations</span></a></li><li id="nav-menu-item-50320" class="menu-item menu-item-type-custom menu-item-object-custom"><a target="_blank" href="https://sso.copyright.com/cas/login?service=https%3A%2F%2Fapcfunding.copyright.com%2Fapc-instportal-ui%2Fj_spring_cas_security_check" class="menu-link sub-menu-link"><span class="js-simple-tooltip" data-simpletooltip-text="Review OA funding requests from your researchers">Institutional Portal</span></a></li></ul></li></ul></nav></div></div></div></header><div data-rocket-location-hash="9aeef69b3a30307314ed240f74205056" id="content" class="site-content"><div data-rocket-location-hash="6b4a57e290647d378e166fed6d3e8b83" id="primary" class="content-area content-area--full-width"><main id="main" class="site-main" role="main"><article id="post-40451" class="post-40451 page type-page status-publish has-post-thumbnail hentry"><div class="stage--1 stage--hero has-background-color has-ringgold-gold-to-white-gold-gradient-background-color"><div class="hero-image-wrapper"><div class="wrapper"><div class="hidden--desk-and-down desktop-breadrumbs spacing--bottom"><div class="breadcrumbs" typeof="BreadcrumbList" vocab="https://schema.org/"> <span property="itemListElement" typeof="ListItem"><a property="item" typeof="WebPage" title="Go to Home" href="https://www.copyright.com" class="home"><span property="name">Home</span></a><meta property="position" content="1"></span> <img aria-hidden="true" alt="" height="8" src="https://www.copyright.com/wp-content/themes/copyrightclearancecenter/assets/images/breadcrumb-separator.svg" width="11" /> <span property="itemListElement" typeof="ListItem"><span property="name">Solutions: Ringgold</span><meta property="position" content="2"></span></div></div><div class="stage--hero__content row clearfix row--flex"><div class="col palm-one-whole lap-one-whole desk-one-half spacing--bottom--half"><figure class="featured-image"><video id="player" playsinline="" loop="" autoplay="" muted="" width="600"></video></figure> <script defer src="data:text/javascript;base64,"></script> </div><div class="col palm-one-whole lap-one-whole desk-one-half"><header><div class="hidden--desk-and-up mobile-breadrumbs"><div class="breadcrumbs" typeof="BreadcrumbList" vocab="https://schema.org/"> <span property="itemListElement" typeof="ListItem"><a property="item" typeof="WebPage" title="Go to Home" href="https://www.copyright.com" class="home"><span property="name">Home</span></a><meta property="position" content="1"></span> <img aria-hidden="true" alt="" height="8" src="https://www.copyright.com/wp-content/themes/copyrightclearancecenter/assets/images/breadcrumb-separator.svg" width="11" /> <span property="itemListElement" typeof="ListItem"><span property="name">Solutions: Ringgold</span><meta property="position" content="2"></span></div></div><h1 class="has-font-size-ccc-h1 has-font-weight-regular custom-hero__title spacing--bottom--half"><span class="has-font-weight-bold">Ringgold</span></h1></header><div class="entry-content entry-content--small"><h2 class="has-font-size-ccc-h6 spacing--bottom"> Improve the quality of organization data with the leading organization persistent identifier (PID) solution trusted by 80 publishers, service providers, and funders for 20 years</h2><div class="wp-block-buttons"><div class="wp-block-button is-style-fill"><a class="wp-block-button__link video-modal-popup has-text-color has-drop-shadow has-background-color" href="https://www.copyright.com/video.php?video_id=evi29ngkfe">Play <svg width="15" height="14" viewBox="0 0 15 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3.33529 0.308689C1.9345 -0.415314 0.798828 0.177798 0.798828 1.63238V12.3666C0.798828 13.8226 1.9345 14.4149 3.33529 13.6916L13.7479 8.31099C15.1491 7.58673 15.1491 6.41333 13.7479 5.68924L3.33529 0.308689Z" fill="currentColor"/></svg></a></div><div class="wp-block-button is-style-fill" style="order: 2;"><a class="wp-block-button__link has-text-color has-drop-shadow has-background-color has-sapphire-background-color has-white-color" href="https://www.copyright.com/landing/contact-ringgold/" href="https://www.copyright.com/landing/contact-ringgold/" onClick="dataLayer.push({'event': 'interactionEvent', 'event_name': 'page_section_click', 'click_text': 'Request information', 'click_url': 'https://www.copyright.com/landing/contact-ringgold/', 'location': 'Solution Header Contact' });">Request information</a></div><div class="wp-block-button is-style-fill wp-block-button--product-sheet"><a class="wp-block-button__link has-text-color" href="https://www.copyright.com/wp-content/uploads/2023/04/ringgold-solutions-product-sheet.pdf" onclick="dataLayer.push({
 'event': 'interactionEvent',
 'event_name': 'asset_download',
