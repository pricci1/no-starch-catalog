figure.aligncenter {
	text-align: center;
}

.wp-block-group.has-spacing-small > p {
	line-height: 1.2;
}

.wp-block-group.has-spacing-small > :first-child {
	margin-bottom: 0;
}

/* Navigation edits */
.mega-menu-callout-card {
  background: #F7F9FA;
  color: #566772;
  font-size: 1rem;
  line-height: 1.25rem;
  position: relative;
}

.mega-menu-callout-card__icon-container {
  border-radius: 0 5px 0 0;
  height: 80px;
  position: absolute;
  text-align: right;
  right: 0;
  top: 0;
  width: 80px;
}

.mega-menu-callout-card__icon-inner {
  background: linear-gradient(45deg, #F7F9FA 50%, transparent 50%);
  height: 100%;
  padding: 7px;
}

#primary-menu-list-desktop .mega-menu-callout-card .mega-menu-callout-card__link-icon {
  fill: currentcolor;
}

.mega-menu-callout-card__link {
  display: block;
  margin-top: 1rem;
}

.mega-menu-callout-card .wp-block-group__inner-container {
  padding: 24px;
}

.mega-menu-callout-card .wp-block-group__inner-container p {
  position: relative;
}

.mega-menu-nav-section-title--indent {
  padding-left: 24px;
}

#solutions-software .menu-item {
  border-right: none;
  padding-left: 0;
}

#solutions-software .menu-item-description {
    font-size: 16px;
    line-height: 1.25;
    margin-top: 0;
}

.mega-menu-callout-card .product-title {
  color: #00326E;
  font-family: SoleilSb, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif;
  font-size: 1.25rem;
  font-weight: normal;
  line-height: 1.5rem;
  margin-bottom: .7rem;
}

#solutions-software  > .wp-block-group__inner-container {
  margin: auto;
  max-width: 1162px;
  padding-top: 0;
}

#solutions-software .wp-block-columns {
  margin-bottom: 0;
}

#solutions-software .wp-block-columns + .wp-block-columns {
  border-top: 1px solid #C9D2D3;
  margin-top: 1.25rem;
  padding-top: 1.25rem;
}

.mega-menu-nav-section-title {
  color: #00A9ED;
  font-family: SoleilBk, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif;
  font-weight: 500;
  font-size: 1rem;
  line-height: 2rem;
  letter-spacing: -0.01875rem;
}

@media (min-width: 768px) {
  .mega-menu #menu-solutions-software .menu-item:nth-child(4) {
    padding-top: 0;
  }
}

